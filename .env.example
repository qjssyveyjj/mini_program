# Docker Compose 环境变量（复制为 .env 后修改）

# 外部 MySQL 连接（不打包 MySQL 镜像，连接已有数据库）
SPRING_DATASOURCE_URL=jdbc:mysql://192.168.16.146:3306/health_management?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-mysql-password

# 百炼 AI API Key
OPENAI_API_KEY=sk-your-dashscope-api-key-here

# 端口映射
SERVER_PORT=8080
CLIENT_PORT=80

# JVM 参数（可选）
JAVA_OPTS=-Xms256m -Xmx512m
