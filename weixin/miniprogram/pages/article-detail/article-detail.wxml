<view class="container" wx:if="{{article}}">
  <view class="card">
    <view class="article-title">{{article.title}}</view>
    <view class="article-meta">
      <text class="category">{{article.category}}</text>
      <text>{{article.viewCount}} 阅读</text>
      <text>{{article.publishTime}}</text>
    </view>
    <view class="article-content">{{article.content}}</view>
  </view>
</view>
