.article-card { transition: transform 0.2s; }
.article-title { font-size: 32rpx; font-weight: 600; color: #333; line-height: 1.4; }
.article-info { display: flex; gap: 20rpx; margin-top: 12rpx; }
.article-category { background: #ede8fd; color: #667eea; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.article-views { font-size: 22rpx; color: #999; line-height: 40rpx; }
.article-preview { font-size: 26rpx; color: #888; margin-top: 16rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
