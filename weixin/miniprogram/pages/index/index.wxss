.index-page { padding-bottom: 20rpx; }

.greeting {
  font-size: 40rpx;
  font-weight: 600;
}

.greeting-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.overview-grid {
  display: flex;
  justify-content: space-between;
}

.overview-item {
  text-align: center;
  flex: 1;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.shortcut-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.shortcut-item {
  width: calc(33.33% - 14rpx);
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.shortcut-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 12rpx;
}

.article-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.article-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
