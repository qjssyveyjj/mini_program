.chat-page { display: flex; flex-direction: column; height: 100vh; background: #f5f6fa; }

.chat-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.chat-avatar { font-size: 48rpx; }
.chat-name { font-size: 30rpx; font-weight: 600; }
.chat-desc { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; }

.chat-messages { flex: 1; padding: 24rpx; overflow-y: auto; }

.message-row { display: flex; margin-bottom: 24rpx; }
.message-row.user { justify-content: flex-end; }
.message-row.assistant { justify-content: flex-start; }

.message-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-bubble.user {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.message-bubble.assistant {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.message-bubble.typing { color: #999; font-style: italic; }

.quick-questions { padding: 0 24rpx 16rpx; }
.quick-title { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.quick-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.quick-item {
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #667eea;
  border: 1rpx solid #e0e0e0;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.chat-input {
  flex: 1;
  background: #f5f6fa;
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 26rpx;
  border-radius: 36rpx;
  padding: 0 32rpx;
  height: 68rpx;
  line-height: 68rpx;
  border: none;
}

.send-btn::after { border: none; }
