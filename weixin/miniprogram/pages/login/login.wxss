.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 16rpx;
}

.login-form {
  width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.btn-login {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.register-link {
  text-align: center;
  color: #667eea;
  font-size: 26rpx;
  margin-top: 32rpx;
}

.login-tip {
  text-align: center;
  color: #bbb;
  font-size: 22rpx;
  margin-top: 24rpx;
}
