.add-btn { text-align: center; padding: 20rpx; color: #667eea; font-size: 28rpx; font-weight: 500; margin-bottom: 16rpx; }
.reminder-header { display: flex; justify-content: space-between; align-items: center; }
.reminder-type { background: #ede8fd; color: #667eea; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; }
.reminder-time { font-size: 28rpx; color: #667eea; font-weight: 600; }
.reminder-title { font-size: 30rpx; font-weight: 500; margin-top: 16rpx; }
.reminder-content { font-size: 26rpx; color: #888; margin-top: 8rpx; }
.reminder-status { font-size: 22rpx; color: #ccc; margin-top: 12rpx; }
.reminder-status.enabled { color: #67c23a; }
.form-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; z-index: 100; }
.form-panel { width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; }
.form-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }
.form-panel input, .picker-field { background: #f5f6fa; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 16rpx; font-size: 28rpx; display: block; }
.form-panel .btn-primary { margin-top: 16rpx; }
