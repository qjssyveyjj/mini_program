.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

.add-btn {
  text-align: center;
  padding: 20rpx;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.record-card .record-date { font-size: 24rpx; color: #999; }
.record-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 12rpx; font-size: 26rpx; color: #555; }
.record-header { display: flex; justify-content: space-between; align-items: center; }
.meal-tag { background: #ede8fd; color: #667eea; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; }
.record-main { font-size: 28rpx; margin-top: 12rpx; color: #333; }
.record-sub { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.form-panel {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
}

.form-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }
.form-body input, .picker-field {
  background: #f5f6fa;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.form-panel .btn-primary { margin-top: 16rpx; }
