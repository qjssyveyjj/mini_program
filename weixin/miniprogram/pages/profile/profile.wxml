<view class="profile-page">
  <view class="gradient-header profile-header">
    <view class="avatar">{{userInfo.nickname ? userInfo.nickname[0] : 'U'}}</view>
    <view class="user-name">{{userInfo.nickname || '用户'}}</view>
    <view class="user-id">@{{userInfo.username}}</view>
  </view>

  <view class="container" style="margin-top: -30rpx">
    <view class="card">
      <view class="info-row"><text class="info-label">性别</text><text>{{genderText}}</text></view>
      <view class="info-row"><text class="info-label">身高</text><text>{{userInfo.height || '--'}} cm</text></view>
      <view class="info-row"><text class="info-label">目标体重</text><text>{{userInfo.targetWeight || '--'}} kg</text></view>
      <view class="info-row"><text class="info-label">手机号</text><text>{{userInfo.phone || '未设置'}}</text></view>
    </view>

    <view class="card menu-card">
      <view class="menu-item" bindtap="goReminder">
        <text>⏰ 健康提醒</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goAiChat">
        <text>🤖 AI健康顾问</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
