<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.mapper.ChatMessageMapper">

    <select id="findByUserId" resultType="com.example.server.entity.ChatMessage">
        SELECT * FROM chat_message WHERE user_id = #{userId} ORDER BY create_time ASC LIMIT #{limit}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message(user_id, role, content) VALUES(#{userId}, #{role}, #{content})
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM chat_message WHERE user_id = #{userId}
    </delete>

</mapper>
